{
    "compilerOptions": {
      "target": "ESNext",
      "module": "commonjs",
      "rootDir": "./src",
      "outDir": "./build",
      "esModuleInterop": true,
      "forceConsistentCasingInFileNames": true,
      "strict": true,
      "skipLibCheck": true,
      "types": ["jest", "node"]
    },
    "include": ["src/**/*.ts"]
  }