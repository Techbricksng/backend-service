// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  firstName String?
  lastName  String?
  email     String   @unique
  role      Role?
  photoUrl  String?
  otpSecret String
  address   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Role {
  ADMIN
  CUSTOMER
  ACCOUNT
  SALES
  MANAGER
  PROPERTY_OWNER
  AGENT
}

model Property {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  price       Float
  location    String
  category    Category
  owner       Owner
  agent       Agent
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("properties")
}

// Embedded types inside Property
type Category {
  name        String
  description String?
}

type Owner {
  userId      String  // Reference to User.id
  name        String
  contactInfo Json?
}

type Agent {
  userId      String  // Reference to User.id
  name        String
  contactInfo Json?
}
