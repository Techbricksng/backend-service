// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  firstName String?
  lastName  String?
  email     String   @unique
  role      Role?
  photoUrl  String?
  otpSecret String
  address   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Role {
  ADMIN
  CUSTOMER
  ACCOUNT
  SALES
  MANAGER
  PROPERTY_OWNER
  AGENT
}

model Property {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  price       Price
  location    String
  category    Category
  owner       Owner
  agent       Agent
  buildingInfo BuildingInfo
  reviews     Review[]  // ✅ Now references the `Review` model (not an embedded type)
  imageIds    String[]  // Array of image IDs (references to the Image collection)
  images      Image[]   @relation("PropertyImages") // ✅ Added this relation field
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("properties")
}


model Image {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  url        String   // URL of the image (stored in cloud storage)
  isDefault  Boolean  @default(false) // Indicates if this is the main photo
  property   Property @relation("PropertyImages", fields: [propertyId], references: [id])
  propertyId String   // Reference to the Property this image belongs to

  @@map("images")
}

type Category {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String  @unique
  description String?
}

type Owner {
  userId      String  @id @map("_id") @db.ObjectId
  name        String
  contactInfo Json?
}

type Agent {
  userId      String  @id @map("_id") @db.ObjectId
  name        String
  contactInfo Json?
}


// New types for Price, BuildingInfo, and Review
type Price {
  houseRent     Float // Base rent for the property
  electricityFee Float // Electricity fee
  damageFee     Float // Damage fee
  otherFee      Float // Other miscellaneous fees
  total         Float // Total price (calculated as the sum of all fees)
}

type BuildingInfo {
  facilities   String[] // Array of facilities/amenities (e.g., "Swimming Pool", "Gym")
  numberOfFloors Int    // Number of floors in the building
  parkingSpaces Int     // Number of parking spaces
}

model Review {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   // Reference to User.id (who wrote the review)
  rating      Int      // Rating out of 5
  comment     String?  // Optional comment
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property   Property @relation(fields: [propertyId], references: [id])
  propertyId String   // Reference to Property.id

  @@map("reviews")
}
